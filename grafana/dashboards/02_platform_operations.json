{
  "uid": "platform-ops",
  "title": "02 · Platform Operations",
  "description": "Real-time health and resource usage for the agent platform. Target audience: platform/SRE team. Shows request rates, latency percentiles, tool usage, session counts, and OTel pipeline health.",
  "tags": ["operations", "sre", "platform"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate — per Framework",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (agent_framework) (rate(agent_request_duration_milliseconds_count[2m]))",
        "legendFormat": "{{agent_framework}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latency Percentiles (P50 / P90 / P99) — all frameworks",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_request_duration_milliseconds_bucket[2m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(agent_request_duration_milliseconds_bucket[2m])))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(agent_request_duration_milliseconds_bucket[2m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Tool Invocation Rate — by Tool",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (tool_name, agent_framework) (rate(agent_tool_call_count_total[2m]))",
        "legendFormat": "{{tool_name}} ({{agent_framework}})"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tool Execution Latency P95 — by Tool",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (tool_name, le) (rate(agent_tool_call_duration_milliseconds_bucket[2m])))",
        "legendFormat": "p95 {{tool_name}}"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Tool Success Rate",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (tool_name) (rate(agent_tool_call_count_total{tool_success=\"true\"}[5m])) / sum by (tool_name) (rate(agent_tool_call_count_total[5m]))",
        "legendFormat": "{{tool_name}}"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "OTel Collector — Spans Received & Exported",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(otelcol_receiver_accepted_spans_total[1m])",
          "legendFormat": "spans received"
        },
        {
          "expr": "rate(otelcol_exporter_sent_spans_total[1m])",
          "legendFormat": "spans exported"
        },
        {
          "expr": "rate(otelcol_exporter_send_failed_spans_total[1m])",
          "legendFormat": "spans failed"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "P95 Latency — LangGraph",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_request_duration_milliseconds_bucket{agent_framework=\"langgraph\"}[5m])))",
        "legendFormat": "p95 langgraph"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "P95 Latency — ADK",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_request_duration_milliseconds_bucket{agent_framework=\"adk\"}[5m])))",
        "legendFormat": "p95 adk"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Total Errors (1 h)",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["sum"] },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 10 }
          ]
        }
      },
      "targets": [{
        "expr": "sum(increase(agent_error_count_total[1h])) or on() vector(0)",
        "legendFormat": "errors"
      }]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Collector Queue Depth",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]
        }
      },
      "targets": [{
        "expr": "otelcol_exporter_queue_size",
        "legendFormat": "queue"
      }]
    }
  ]
}
